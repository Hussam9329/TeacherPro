# TeacherPro / Vercel
# ضع نفس القيم في Vercel Project Settings > Environment Variables

# مطلوب لتشغيل API وقاعدة البيانات في الإنتاج
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# اختياري عند استخدام اتصال مباشر لتشغيل migrations محليًا أو من CI
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# اختياري؛ Vercel يضبطه تلقائيًا في العادة
NODE_ENV="production"

# مطلوب بعد تفعيل حماية API: سر طويل وعشوائي لتوقيع جلسات الدخول
TEACHERPRO_AUTH_SECRET="replace-with-a-long-random-secret"

# كلمة مرور مدير النظام الافتراضية (تُستخدم فقط عند إنشاء حساب admin
# لأول مرة، أو ترحيل كلمات المرور القديمة).
# غيّرها إلى قيمة قوية وفريدة قبل النشر.
TEACHERPRO_ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# كلمات مرور admin القديمة التي تريد ترحيلها تلقائياً إلى
# TEACHERPRO_ADMIN_PASSWORD عند أول تشغيل بعد التحديث.
# افصل بينها بفواصل. اتركها فارغة إذا لا توجد كلمات قديمة للترحيل.
# مثال: TEACHERPRO_LEGACY_ADMIN_PASSWORDS="oldpass1,oldpass2"
# احذف هذا المتغير بعد الترحيل لتفادي الاحتفاظ بكلمات قديمة في الـ env.
TEACHERPRO_LEGACY_ADMIN_PASSWORDS=""

# رابط TeacherPro الذي يضعه بوت التليغرام في ملف البيئة الخاص به.
# محلياً غالباً: http://localhost:3000
# بالإنتاج: رابط الدومين المنشور مثل https://teacherpro.example.com
TEACHERPRO_API_URL="https://teacherpro-eight.vercel.app"

# Token used by Telegram bot to push submitted answer sheets into TeacherPro.
# Send it as Authorization: Bearer <token> or x-teacherpro-bot-token.
TEACHERPRO_BOT_INGEST_TOKEN="replace-with-a-long-random-bot-ingest-token"

# نفس التوكن أعلاه يستخدمه البوت أيضاً للوصول الآمن إلى مسارات:
# /api/bot/students/resolve
# /api/bot/students/link
# /api/bot/exams
# /api/bot/opportunities
# /api/telegram-exam-submissions

# Telegram Bot Token (from @BotFather). Used by TeacherPro to fetch
# image files from Telegram when a corrector opens a submission.
# بدون هذا التوكن، الصور المرسلة عبر fileId لن تظهر في صفحة التصحيح.
TEACHERPRO_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz"

# Rate limit موزّع لتسجيل الدخول (Upstash Redis REST API).
# أنشئ حساب مجاني على https://upstash.com وأنشئ Redis database،
# ثم انسخ REST URL و REST Token هنا.
# بدون هذه القيم، يشتغل rate limit محلياً (لكل instance) كـ fallback.
UPSTASH_REDIS_REST_URL="https://xxx-xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-rest-token"

# ─── Cloudflare R2 (تخزين صور البوت) ──────────────────────────────────────
# R2 هو تخزين كائنات (S3-compatible) من Cloudflare. يُستخدم لتخزين صور
# مستلمات البوت (Telegram submissions) بشكل دائم وسريع.
# عند أول فتح لصورة، يقوم الخادم بتحميلها من Telegram ورفعها إلى R2.
# كلفتح لاحق يكون عبر CDN من R2 (سريع وموثوق، لا ERR_CONNECTION_TIMED_OUT).
#
# القيم من Cloudflare Dashboard > R2 > [Bucket] > Settings:
# R2_ENDPOINT: S3 API endpoint (https://<account>.r2.cloudflarestorage.com)
# R2_ACCESS_KEY_ID: Access Key ID من R2 > Manage R2 API Tokens
# R2_SECRET_ACCESS_KEY: Secret Access Key
# R2_BUCKET_NAME: اسم الـ bucket (مثلاً teacherpro)
# R2_PUBLIC_BASE_URL: رابط الوصول العام (https://pub-xxx.r2.dev)
#
# بدون هذه القيم، الصور تُخدم مباشرة من Telegram (قد تكون بطيئة).
R2_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="teacherpro"
R2_PUBLIC_BASE_URL="https://pub-xxxxx.r2.dev"
