# TeacherPro / Vercel
# ضع نفس القيم في Vercel Project Settings > Environment Variables

# مطلوب لتشغيل API وقاعدة البيانات في الإنتاج
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# اختياري عند استخدام اتصال مباشر لتشغيل migrations محليًا أو من CI
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# اختياري؛ Vercel يضبطه تلقائيًا في العادة
NODE_ENV="production"

# مطلوب بعد تفعيل حماية API: سر طويل وعشوائي لتوقيع جلسات الدخول
TEACHERPRO_AUTH_SECRET="replace-with-a-long-random-secret"

# رابط TeacherPro الذي يضعه بوت التليغرام في ملف البيئة الخاص به.
# محلياً غالباً: http://localhost:3000
# بالإنتاج: رابط الدومين المنشور مثل https://teacherpro.example.com
TEACHERPRO_API_URL="http://localhost:3000"

# Token used by Telegram bot to push submitted answer sheets into TeacherPro.
# Send it as Authorization: Bearer <token> or x-teacherpro-bot-token.
TEACHERPRO_BOT_INGEST_TOKEN="change-this-long-random-token"
